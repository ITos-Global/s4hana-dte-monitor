<mvc:View
    controllerName="com.fenixgold.dte.monitordte.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:comp="sap.ui.comp.smarttable"
    xmlns:sfb="sap.ui.comp.smartfilterbar"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <f:DynamicPage id="dynamicPage" headerExpanded="true" toggleHeaderOnTitleClick="false">

        <!-- ================================================================
             TÍTULO
             ================================================================ -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>appTitle}" level="H2"/>
                </f:heading>
                <f:snappedContent>
                    <Text text="{i18n>appDescription}"/>
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ================================================================
             FILTROS — SmartFilterBar lee anotaciones @UI.selectionField del CDS
             ================================================================ -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <sfb:SmartFilterBar
                    id="filterBar"
                    entitySet="DteMonitor"
                    persistencyKey="DteMonitorFilter"
                    search=".onSearch"
                    showRestoreButton="true"
                    showClearButton="true"
                    useToolbar="false">
                    <!-- Campos adicionales no cubiertos por anotaciones CDS -->
                    <sfb:controlConfiguration>
                        <sfb:ControlConfiguration
                            key="FechaDocumento"
                            visibleInAdvancedArea="false"
                            preventInitialDataFetchInValueHelpDialog="false">
                            <sfb:customControl>
                                <DateRangeSelection
                                    id="drsFechaDoc"
                                    delimiter="-"
                                    displayFormat="dd/MM/yyyy"/>
                            </sfb:customControl>
                        </sfb:ControlConfiguration>
                        <sfb:ControlConfiguration
                            key="FechaRecepcionSii"
                            visibleInAdvancedArea="false">
                            <sfb:customControl>
                                <DateRangeSelection
                                    id="drsFechaRecep"
                                    delimiter="-"
                                    displayFormat="dd/MM/yyyy"/>
                            </sfb:customControl>
                        </sfb:ControlConfiguration>
                    </sfb:controlConfiguration>
                </sfb:SmartFilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ================================================================
             CONTENIDO — SmartTable con GridTable
             ================================================================ -->
        <f:content>
            <comp:SmartTable
                id="monitorTable"
                entitySet="DteMonitor"
                smartFilterId="filterBar"
                tableType="GridTable"
                useVariantManagement="true"
                useTablePersonalisation="true"
                header="{i18n>tableTitle}"
                showRowCount="true"
                enableExport="true"
                useExportToExcel="true"
                requestAtLeastFields="Estado,DiasPendientes,Criticality,XmlData"
                initiallyVisibleFields="Sociedad,TipoDte,Folio,Proveedor,NombreProveedor,Estado,FechaDocumento,FechaRecepcionSii,TotalDocumento,DiasPendientes"
                class="sapUiResponsiveContentPadding">

                <!-- --------------------------------------------------------
                     TOOLBAR DE ACCIONES
                     -------------------------------------------------------- -->
                <comp:customToolbar>
                    <OverflowToolbar style="Clear">
                        <ToolbarSpacer/>

                        <Button
                            id="btnReprocesar"
                            text="{i18n>btnReprocesar}"
                            icon="sap-icon://refresh"
                            enabled="false"
                            press=".onReprocesar"
                            tooltip="{i18n>btnReprocesarTooltip}"/>

                        <Button
                            id="btnVerPdf"
                            text="{i18n>btnVerPdf}"
                            icon="sap-icon://pdf-attachment"
                            enabled="false"
                            press=".onVerPdf"
                            tooltip="{i18n>btnVerPdfTooltip}"/>

                        <Button
                            id="btnDocRef"
                            text="{i18n>btnDocRef}"
                            icon="sap-icon://add-document"
                            enabled="false"
                            press=".onIndicarDocRef"
                            tooltip="{i18n>btnDocRefTooltip}"/>

                        <Button
                            id="btnPosiciones"
                            text="{i18n>btnPosiciones}"
                            icon="sap-icon://detail-view"
                            enabled="false"
                            press=".onIndicarPosiciones"
                            tooltip="{i18n>btnPosicionesTooltip}"/>

                        <Button
                            id="btnRechazar"
                            text="{i18n>btnRechazar}"
                            icon="sap-icon://decline"
                            type="Reject"
                            enabled="false"
                            press=".onRechazar"
                            tooltip="{i18n>btnRechazarTooltip}"/>

                    </OverflowToolbar>
                </comp:customToolbar>

                <!-- --------------------------------------------------------
                     CONFIGURACIÓN INTERNA DEL GRID TABLE
                     (SmartTable genera las columnas desde anotaciones CDS;
                      aquí configuramos comportamiento del grid interno)
                     -------------------------------------------------------- -->
                <comp:customizeConfig>
                    <table:Column
                        id="colEstado"
                        width="8rem"
                        label="Estado"
                        autoResizable="true">
                        <table:template>
                            <ObjectStatus
                                text="{path: 'Estado', formatter: '.formatter.estadoText'}"
                                state="{path: 'Criticality', formatter: '.formatter.criticalityToState'}"
                                icon="{path: 'Criticality', formatter: '.formatter.criticalityToIcon'}"
                                inverted="false"/>
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="colDiasPend"
                        width="7rem"
                        label="Días Pend."
                        autoResizable="true">
                        <table:template>
                            <ObjectStatus
                                text="{DiasPendientes}"
                                state="{path: 'CriticalityDias', formatter: '.formatter.criticalityToState'}"
                                icon="{path: 'CriticalityDias', formatter: '.formatter.criticalityToIcon'}"
                                inverted="false"/>
                        </table:template>
                    </table:Column>
                </comp:customizeConfig>

            </comp:SmartTable>
        </f:content>

    </f:DynamicPage>

</mvc:View>
