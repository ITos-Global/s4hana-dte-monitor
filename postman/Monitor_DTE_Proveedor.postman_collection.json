    {
      "name": "4 — Historial DTE",
      "description": "Consultas a la entidad hijo DteHistorial.",
      "item": [
        {
          "name": "Historial de un DTE específico",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')/DteHistorial?$orderby=Timestamp desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": [
                "DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')",
                "DteHistorial"
              ],
              "query": [{ "key": "$orderby", "value": "Timestamp desc" }]
            },
            "description": "Todos los cambios de estado de un DTE, ordenados por timestamp descendente."
          }
        },
        {
          "name": "Todos los movimientos de hoy",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteHistorial?$filter=Timestamp ge 2026-04-16T00:00:00Z&$orderby=Timestamp desc&$top=100",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteHistorial"],
              "query": [
                { "key": "$filter",  "value": "Timestamp ge 2026-04-16T00:00:00Z" },
                { "key": "$orderby", "value": "Timestamp desc" },
                { "key": "$top",     "value": "100" }
              ]
            },
            "description": "Log de auditoría de todos los cambios realizados hoy en el monitor."
          }
        }
      ]
    },
