*.abap text eol=lf
*.asddls text eol=lf
*.asddlxs text eol=lf
*.asdcls text eol=lf
*.asbdef text eol=lf
*.assdls text eol=lf
*.asbdef text eol=lf

# Frontend / config — let the OS decide
*.json text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.js text eol=lf
*.properties text eol=lf
