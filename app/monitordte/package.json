{
  "name": "com.fenixgold.dte.monitordte",
  "version": "1.0.0",
  "description": "Monitor DTE Proveedor",
  "private": true,
  "scripts": {
    "start":       "fiori run --open index.html",
    "start-local": "dotenv -- fiori run --config ui5-local.yaml --open index.html",
    "build":       "ui5 build --clean-dest",
    "build:cf":    "ui5 build --config ui5.yaml --clean-dest && npm run package",
    "package":     "node -e \"require('fs').mkdirSync('../app-content',{recursive:true})\" && cd dist && bestzip ../../app-content/dte-monitor-app-content.zip *",
    "lint":        "eslint webapp"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "^1",
    "@ui5/cli": "^4",
    "bestzip": "^2.2.1",
    "dotenv-cli": "^7"
  }
}
