{
  "info": {
    "name": "Monitor DTE Proveedor — S/4HANA OData V4",
    "_postman_id": "dte-monitor-v1",
    "description": "Colección para el bot de registro y consulta de DTE.\n\nConfigura las variables de entorno antes de usar:\n- `s4hana_host`: host del tenant S/4HANA\n- `s4hana_user` / `s4hana_pass`: credenciales de servicio\n- `csrf_token`: se obtiene automáticamente con la request 'Fetch CSRF Token'\n\nServicio OData V4: ZUI_DTE_MONITOR_O4",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "s4hana_host",
      "value": "https://my-tenant.s4hana.ondemand.com",
      "type": "string"
    },
    {
      "key": "service_root",
      "value": "/sap/opu/odata4/sap/zui_dte_monitor_o4/srvd/sap/zui_dte_monitor/0001",
      "type": "string"
    },
    {
      "key": "csrf_token",
      "value": "fetch",
      "type": "string"
    },
    {
      "key": "tipo_dte",
      "value": "033",
      "type": "string"
    },
    {
      "key": "folio",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "proveedor_rut",
      "value": "76543210-9",
      "type": "string"
    },
    {
      "key": "sociedad",
      "value": "1000",
      "type": "string"
    }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{s4hana_user}}", "type": "string" },
      { "key": "password", "value": "{{s4hana_pass}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "0 — Setup",
      "description": "Obtención de CSRF token y metadata del servicio.",
      "item": [
        {
          "name": "Fetch CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const token = pm.response.headers.get('x-csrf-token');",
                  "if (token) {",
                  "    pm.collectionVariables.set('csrf_token', token);",
                  "    pm.test('CSRF token obtenido: ' + token, () => pm.expect(token).to.not.be.empty);",
                  "} else {",
                  "    pm.test('CSRF token NO obtenido', () => pm.expect.fail('Header x-csrf-token ausente'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-csrf-token", "value": "fetch" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": [""]
            },
            "description": "Obtiene el CSRF token y lo guarda como variable de colección. Ejecutar antes de cualquier POST/PATCH."
          }
        },
        {
          "name": "Service Metadata ($metadata)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/xml" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/$metadata",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["$metadata"]
            },
            "description": "Retorna el esquema EDMX del servicio OData V4. Útil para verificar tipos de campo y acciones disponibles."
          }
        }
      ]
    },
    {
      "name": "1 — Bot Consultas (GET)",
      "description": "Requests de lectura que el bot usa para consultar el estado del monitor.",
      "item": [
        {
          "name": "Listar todos los DTE",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$orderby=FechaRecepcionSii desc&$top=50",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$orderby", "value": "FechaRecepcionSii desc" },
                { "key": "$top",     "value": "50" }
              ]
            },
            "description": "Lista los últimos 50 DTE ordenados por fecha de recepción SII."
          }
        },
        {
          "name": "DTE Pendientes de procesar (Estado 01 y 05)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$filter=(Estado eq '01' or Estado eq '05')&$select=TipoDte,Folio,Proveedor,NombreProveedor,Estado,FechaDocumento,FechaRecepcionSii,TotalDocumento,Moneda,OrdenCompra,DiasPendientes&$orderby=DiasPendientes desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$filter",  "value": "(Estado eq '01' or Estado eq '05')" },
                { "key": "$select",  "value": "TipoDte,Folio,Proveedor,NombreProveedor,Estado,FechaDocumento,FechaRecepcionSii,TotalDocumento,Moneda,OrdenCompra,DiasPendientes" },
                { "key": "$orderby", "value": "DiasPendientes desc" }
              ]
            },
            "description": "Consulta los DTE que el bot debe procesar: Pendientes (01) y No procesados (05). Ordenados por días pendientes descendente para priorizar los más urgentes."
          }
        },
        {
          "name": "DTE Por rechazar (Estado 04) — requieren intervención",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$filter=Estado eq '04'&$select=TipoDte,Folio,Proveedor,NombreProveedor,FechaDocumento,TotalDocumento,Moneda,OrdenCompra,HojaEntradaServicio,EntradaMercancia,LogProcesamiento,DiasPendientes&$orderby=DiasPendientes desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$filter",  "value": "Estado eq '04'" },
                { "key": "$select",  "value": "TipoDte,Folio,Proveedor,NombreProveedor,FechaDocumento,TotalDocumento,Moneda,OrdenCompra,HojaEntradaServicio,EntradaMercancia,LogProcesamiento,DiasPendientes" },
                { "key": "$orderby", "value": "DiasPendientes desc" }
              ]
            },
            "description": "DTE que fallaron validación y esperan que el usuario indique el documento de referencia. El bot puede alertar sobre estos."
          }
        },
        {
          "name": "DTE con alerta días (≥ 5 días pendientes)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$filter=(Estado eq '01' or Estado eq '04' or Estado eq '05') and DiasPendientes ge 5&$select=TipoDte,Folio,Proveedor,NombreProveedor,Estado,TotalDocumento,Moneda,DiasPendientes&$orderby=DiasPendientes desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$filter",  "value": "(Estado eq '01' or Estado eq '04' or Estado eq '05') and DiasPendientes ge 5" },
                { "key": "$select",  "value": "TipoDte,Folio,Proveedor,NombreProveedor,Estado,TotalDocumento,Moneda,DiasPendientes" },
                { "key": "$orderby", "value": "DiasPendientes desc" }
              ]
            },
            "description": "Alerta: DTE que llevan 5+ días sin resolverse. El bot puede enviar notificaciones basadas en este resultado."
          }
        },
        {
          "name": "Buscar DTE por RUT Proveedor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$filter=Proveedor eq '{{proveedor_rut}}'&$orderby=FechaDocumento desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$filter",  "value": "Proveedor eq '{{proveedor_rut}}'" },
                { "key": "$orderby", "value": "FechaDocumento desc" }
              ]
            },
            "description": "Todos los DTE de un proveedor específico (por RUT). Ajustar la variable proveedor_rut."
          }
        },
        {
          "name": "Buscar DTE por Folio + Tipo + RUT (clave exacta)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')"]
            },
            "description": "Obtiene un DTE específico por su clave compuesta (TipoDte + Folio + RUT Proveedor). Usar para verificar si un DTE ya existe antes de crearlo."
          }
        },
        {
          "name": "DTE con $expand Historial",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')?$expand=_Historial($orderby=Timestamp desc)",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')"],
              "query": [
                { "key": "$expand", "value": "_Historial($orderby=Timestamp desc)" }
              ]
            },
            "description": "Obtiene el DTE junto con su historial de cambios de estado."
          }
        },
        {
          "name": "Conteo de DTE por Estado ($apply groupby)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$apply=groupby((Estado),aggregate($count as Count))&$orderby=Estado",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$apply",   "value": "groupby((Estado),aggregate($count as Count))" },
                { "key": "$orderby", "value": "Estado" }
              ]
            },
            "description": "Resumen de cuántos DTE hay en cada estado. Útil para el dashboard del bot."
          }
        },
        {
          "name": "DTE por Sociedad y rango de fecha",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor?$filter=Sociedad eq '{{sociedad}}' and FechaRecepcionSii ge 2026-04-01 and FechaRecepcionSii le 2026-04-30&$select=TipoDte,Folio,Proveedor,NombreProveedor,Estado,TotalDocumento,Moneda,FechaRecepcionSii&$orderby=FechaRecepcionSii desc",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor"],
              "query": [
                { "key": "$filter",  "value": "Sociedad eq '{{sociedad}}' and FechaRecepcionSii ge 2026-04-01 and FechaRecepcionSii le 2026-04-30" },
                { "key": "$select",  "value": "TipoDte,Folio,Proveedor,NombreProveedor,Estado,TotalDocumento,Moneda,FechaRecepcionSii" },
                { "key": "$orderby", "value": "FechaRecepcionSii desc" }
              ]
            },
            "description": "DTE de una sociedad en un rango de fechas específico."
          }
        }
      ]
    },
    {
      "name": "2 — Bot Registro DTE (POST/PATCH)",
      "description": "El bot crea registros nuevos cuando recibe un XML del SII o casilla de correo.",
      "item": [
        {
          "name": "Crear DTE — Factura Afecta (Tipo 033)",
