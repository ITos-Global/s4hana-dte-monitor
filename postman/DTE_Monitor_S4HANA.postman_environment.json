{
  "id": "dte-monitor-env",
  "name": "DTE Monitor — S/4HANA (DEV)",
  "values": [
    {
      "key": "s4hana_host",
      "value": "https://my-tenant.s4hana.ondemand.com",
      "type": "default",
      "enabled": true,
      "description": "Host del tenant S/4HANA Public Edition (sin barra final)"
    },
    {
      "key": "service_root",
      "value": "/sap/opu/odata4/sap/zui_dte_monitor_o4/srvd/sap/zui_dte_monitor/0001",
      "type": "default",
      "enabled": true,
      "description": "Ruta raíz del servicio OData V4. Ajustar si el namespace difiere. Verificar en ADT → Service Binding → Published URL."
    },
    {
      "key": "s4hana_user",
      "value": "ZDT_BOT_USER",
      "type": "secret",
      "enabled": true,
      "description": "Usuario SAP del bot (debe tener rol DteMonitorProcessor o Admin)"
    },
    {
      "key": "s4hana_pass",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Password del usuario SAP (completar en local, NO commitear)"
    },
    {
      "key": "csrf_token",
      "value": "fetch",
      "type": "default",
      "enabled": true,
      "description": "Se actualiza automáticamente al ejecutar 'Fetch CSRF Token'"
    },
    {
      "key": "tipo_dte",
      "value": "033",
      "type": "default",
      "enabled": true,
      "description": "Tipo DTE para requests individuales: 033=FA, 034=FE, 046=FC, 055=ND, 056=NC"
    },
    {
      "key": "folio",
      "value": "123456",
      "type": "default",
      "enabled": true,
      "description": "Folio del DTE para requests individuales"
    },
    {
      "key": "proveedor_rut",
      "value": "76543210-9",
      "type": "default",
      "enabled": true,
      "description": "RUT proveedor con dígito verificador (formato XXXXXXXX-X)"
    },
    {
      "key": "sociedad",
      "value": "1000",
      "type": "default",
      "enabled": true,
      "description": "Código de sociedad SAP (BUKRS)"
    }
  ],
  "_postman_variable_scope": "environment"
}
