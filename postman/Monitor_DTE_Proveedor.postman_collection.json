        {
          "name": "Crear DTE — Factura de Compra (Tipo 046)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "x-csrf-token",  "value": "{{csrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TipoDte\": \"046\",\n  \"Folio\": \"3301\",\n  \"Proveedor\": \"11111111-1\",\n  \"Sociedad\": \"1000\",\n  \"ProveedorSap\": \"0000099001\",\n  \"NombreProveedor\": \"AGRICOLA EL CAMPO S.A.\",\n  \"FechaDocumento\": \"2026-04-08\",\n  \"FechaRecepcionSii\": \"2026-04-09\",\n  \"FechaAceptacion\": \"2026-04-09\",\n  \"FechaVencimiento\": \"2026-05-08\",\n  \"Estado\": \"01\",\n  \"MontoNeto\": 800000,\n  \"MontoExento\": 0,\n  \"Iec\": 0,\n  \"IvaRecuperable\": 0,\n  \"IvaNoRecuperable\": 0,\n  \"IvaRetenido\": 152000,\n  \"TotalDocumento\": 800000,\n  \"Moneda\": \"CLP\",\n  \"OrdenCompra\": \"4500098765\",\n  \"EntradaMercancia\": \"\",\n  \"AnioEntradaMercancia\": \"\",\n  \"HojaEntradaServicio\": \"\",\n  \"FolioReferencia\": \"\",\n  \"XmlData\": \"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?><DTE><Encabezado><IdDoc><TipoDTE>46</TipoDTE><Folio>3301</Folio></IdDoc><Emisor><RUTEmisor>11111111-1</RUTEmisor></Emisor><Totales><MntNeto>800000</MntNeto><IVARetTotal>152000</IVARetTotal><MntTotal>800000</MntTotal></Totales></Encabezado></DTE>\",\n  \"LogProcesamiento\": \"\"\n}",
