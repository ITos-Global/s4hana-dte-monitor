        {
          "name": "Actualizar Log de procesamiento (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "x-csrf-token",  "value": "{{csrf_token}}" },
              { "key": "If-Match",      "value": "*" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"LogProcesamiento\": \"[2026-04-16 10:30:00] Bot: XML recibido OK. Proveedor validado en SAP. OC 4500012345 encontrada. Monto OC: 1.800.000 CLP. Diferencia: 15.000 CLP (0,84% — dentro de tolerancia 5%). Enviando a contabilización...\",\n  \"Estado\": \"01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{s4hana_host}}{{service_root}}/DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')",
              "host": ["{{s4hana_host}}{{service_root}}"],
              "path": ["DteMonitor(TipoDte='{{tipo_dte}}',Folio='{{folio}}',Proveedor='{{proveedor_rut}}')"]
            },
            "description": "El bot actualiza el campo LogProcesamiento con el resultado de sus validaciones. Usar If-Match: * para omitir ETag (o usar el ETag real de la respuesta GET prevía)."
          }
        }
      ]
    },
    {
      "name": "3 — Acciones RAP (POST actions)",
