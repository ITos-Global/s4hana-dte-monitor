            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "x-csrf-token",  "value": "{{csrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TipoDte\": \"033\",\n  \"Folio\": \"123456\",\n  \"Proveedor\": \"76543210-9\",\n  \"Sociedad\": \"1000\",\n  \"ProveedorSap\": \"0000012345\",\n  \"NombreProveedor\": \"SERVICIOS MINEROS S.A.\",\n  \"FechaDocumento\": \"2026-04-10\",\n  \"FechaRecepcionSii\": \"2026-04-11\",\n  \"FechaAceptacion\": \"2026-04-11\",\n  \"FechaVencimiento\": \"2026-05-10\",\n  \"Estado\": \"01\",\n  \"MontoNeto\": 1500000,\n  \"MontoExento\": 0,\n  \"Iec\": 0,\n  \"IvaRecuperable\": 285000,\n  \"IvaNoRecuperable\": 0,\n  \"IvaRetenido\": 0,\n  \"TotalDocumento\": 1785000,\n  \"Moneda\": \"CLP\",\n  \"OrdenCompra\": \"4500012345\",\n  \"EntradaMercancia\": \"\",\n  \"AnioEntradaMercancia\": \"\",\n  \"HojaEntradaServicio\": \"\",\n  \"FolioReferencia\": \"\",\n  \"XmlData\": \"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?><DTE><Encabezado><IdDoc><TipoDTE>33</TipoDTE><Folio>123456</Folio><FchEmis>2026-04-10</FchEmis></IdDoc><Emisor><RUTEmisor>76543210-9</RUTEmisor><RznSoc>SERVICIOS MINEROS S.A.</RznSoc></Emisor><Receptor><RUTRecep>12345678-9</RUTRecep><RznSocRecep>FENIX GOLD S.A.</RznSocRecep></Receptor><Totales><MntNeto>1500000</MntNeto><TasaIVA>19</TasaIVA><IVA>285000</IVA><MntTotal>1785000</MntTotal></Totales></Encabezado><Referencia><NroLinRef>1</NroLinRef><TpoDocRef>801</TpoDocRef><FolioRef>4500012345</FolioRef></Referencia></DTE>\",\n  \"LogProcesamiento\": \"\"\n}",
